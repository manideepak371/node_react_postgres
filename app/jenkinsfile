pipeline{
    agent any
    stages{
        stage('Build Image'){
            echo "build started"
            sh "docker build -t manideepak371/node_react_postgres:$BUILD_NUMBER ."
        }

        stage('Deploy'){
            echo "deployment started"
            sh "docker run -d -p 7000:7000 manideepak371/node_react_postgres:$BUILD_NUMBER"
        }
    }
}



